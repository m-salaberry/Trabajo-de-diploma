            }
            catch (Exception ex)
            {
                MessageBox.Show(lang.Translate("UnexpectedError") + "\n\n" + ex.Message, lang.Translate("Error"), MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
    }
