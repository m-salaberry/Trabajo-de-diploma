        public void Create(Item entity)
        {
            string command = "INSERT INTO ITEMS (Name, Unit, IntegerUnit, ItemsCategoryId, CurrentStock) VALUES (@Name, @Unit, @IntegerUnit, @ItemsCategoryId, @CurrentStock); SELECT CAST(SCOPE_IDENTITY() AS UNIQUEIDENTIFIER)";
            var parameters = new[]
            {
                new SqlParameter("@Name", entity.Name),
                new SqlParameter("@Unit", entity.Unit),
                new SqlParameter("@IntegerUnit", entity.Unit),
                new SqlParameter("@ItemsCategoryId", (long)entity.Category),
                new SqlParameter("@CurrentStock", entity.Stock)
            };

            var result = SqlHelper.ExecuteScalar(command, CommandType.Text, parameters);
            if (result != null)
            {
                entity.Id = (Guid)result;
            }
        }

