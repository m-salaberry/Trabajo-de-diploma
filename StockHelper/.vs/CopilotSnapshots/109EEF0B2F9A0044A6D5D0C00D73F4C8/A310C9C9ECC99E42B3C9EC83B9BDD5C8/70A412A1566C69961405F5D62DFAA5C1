    ProductoNombre AS Producto,
    ComponenteNombre AS Componente,
    CantidadConsumida AS Cantidad,
    Orden
FROM vw_ComposicionProductos
WHERE ProductoNombre LIKE '%Pizza%'
ORDER BY Orden;
PRINT '';

-- Test 3: Simular actualización de stock
PRINT '--- Test 3: Actualizar Stock (Restar 100g de Harina) ---';
DECLARE @ItemIdTest UNIQUEIDENTIFIER;
SELECT @ItemIdTest = Id FROM ITEMS WHERE Nombre LIKE 'Harina%';
EXEC sp_UpdateStock @ItemId = @ItemIdTest, @CantidadCambio = 100, @Operacion = 'SUBTRACT';
PRINT '';

-- Test 4: Ver proveedores con mejor precio
PRINT '--- Test 4: Proveedores por Item con Mejor Precio ---';
SELECT 
    ItemNombre AS Item,
    ProveedorNombre AS Proveedor,
    PrecioCompra AS Precio,
    CASE WHEN EsProveedorPrincipal = 1 THEN '⭐' ELSE '' END AS Principal
FROM vw_ItemsConProveedores
ORDER BY ItemNombre, PrecioCompra ASC;
PRINT '';

