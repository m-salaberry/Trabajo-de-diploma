SELECT 
    i.Nombre AS Item,
    c.Nombre AS Categoria,
    s.Cantidad AS Stock,
    s.StockMinimo AS Min,
    s.StockMaximo AS Max,
    CASE 
        WHEN s.Cantidad <= 0 THEN 'рҹ”ҙ Sin Stock'
        WHEN s.Cantidad <= s.StockMinimo THEN 'рҹҹЎ Stock Bajo'
        WHEN s.Cantidad >= s.StockMaximo THEN 'рҹҹў Stock Alto'
        ELSE 'вң… Normal'
    END AS Estado
FROM ITEMS i
INNER JOIN STOCK s ON i.Id = s.ItemId
INNER JOIN CATEGORIA_ITEMS c ON i.CategoriaId = c.Id
WHERE i.IsActive = 1
ORDER BY s.Cantidad ASC;
```

### **2. Obtener proveedores de un item:**
```sql
SELECT 
    p.Nombre,
    p.CUIT,
    p.TelefonoContacto,
    ip.PrecioCompra,
    CASE WHEN ip.EsProveedorPrincipal = 1 THEN 'вӯҗ Principal' ELSE '' END AS Estado
FROM PROVEEDORES p
INNER JOIN ITEMS_PROVEEDORES ip ON p.Id = ip.ProveedorId
WHERE ip.ItemId = @ItemId AND p.IsActive = 1
ORDER BY ip.EsProveedorPrincipal DESC, p.Nombre;
```

### **3. Obtener componentes de un producto:**
```sql
SELECT 
    iComp.Nombre AS Componente,
    dp.CantidadConsumida AS Cantidad,
    iComp.Unidad AS UnidadMedida,
    s.Cantidad AS StockDisponible
FROM DETALLE_PRODUCTO dp
INNER JOIN ITEMS iComp ON dp.ItemComponenteId = iComp.Id
INNER JOIN STOCK s ON iComp.Id = s.ItemId
WHERE dp.ItemPadreId = @ProductoId
ORDER BY dp.Orden;
```

### **4. Items mГЎs vendidos/usados (preparado para futuro):**
```sql
-- Esta query estarГЎ lista cuando implementes Гіrdenes/ventas
SELECT 
    i.Nombre,
    COUNT(rp.ItemId) AS VecesUsado
FROM ITEMS i
LEFT JOIN RENGLON_PEDIDO rp ON i.Id = rp.ItemId
GROUP BY i.Nombre
ORDER BY VecesUsado DESC;
```

### **5. Calcular si hay stock suficiente para producir:**
```sql
-- Verificar si hay componentes suficientes para producir N unidades de un producto
DECLARE @ProductoId UNIQUEIDENTIFIER = '...';
DECLARE @CantidadProducir INT = 10;

SELECT 
    iComp.Nombre AS Componente,
    dp.CantidadConsumida * @CantidadProducir AS CantidadNecesaria,
    s.Cantidad AS StockDisponible,
    CASE 
        WHEN s.Cantidad >= (dp.CantidadConsumida * @CantidadProducir) 
        THEN 'вң… Suficiente' 
        ELSE 'вқҢ Insuficiente' 
    END AS Estado
FROM DETALLE_PRODUCTO dp
INNER JOIN ITEMS iComp ON dp.ItemComponenteId = iComp.Id
INNER JOIN STOCK s ON iComp.Id = s.ItemId
WHERE dp.ItemPadreId = @ProductoId;
```

