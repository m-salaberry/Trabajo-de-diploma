## 📦 **DATOS DE EJEMPLO**

### **Ejemplo completo de insert:**

```sql
BEGIN TRANSACTION;

-- 1. Categorías
INSERT INTO CATEGORIA_ITEMS (Nombre) VALUES ('Productos Terminados');
INSERT INTO CATEGORIA_ITEMS (Nombre) VALUES ('Materias Primas');

DECLARE @CatTerminados INT = SCOPE_IDENTITY();
DECLARE @CatPrimas INT = (SELECT Id FROM CATEGORIA_ITEMS WHERE Nombre = 'Materias Primas');

-- 2. Items simples (componentes)
DECLARE @HarinaId UNIQUEIDENTIFIER = NEWID();
DECLARE @QuesoId UNIQUEIDENTIFIER = NEWID();
DECLARE @TomateId UNIQUEIDENTIFIER = NEWID();

INSERT INTO ITEMS (Id, Nombre, Unidad, UnidadEntera, CategoriaId) VALUES
    (@HarinaId, 'Harina 0000', 1.0, 0, @CatPrimas),    -- Se vende por kg (puede ser 0.5kg)
    (@QuesoId, 'Queso Mozzarella', 1.0, 0, @CatPrimas),
    (@TomateId, 'Salsa de Tomate', 1.0, 0, @CatPrimas);

-- El trigger crea automáticamente registros en STOCK con Cantidad = 0

-- 3. Proveedor
DECLARE @ProveedorId UNIQUEIDENTIFIER = NEWID();
INSERT INTO PROVEEDORES (Id, CUIT, Nombre, RazonSocial, TelefonoContacto) VALUES
    (@ProveedorId, 20345678901, 'Distribuidora Norte', 'Norte Distribuciones S.A.', 1145678901);

-- 4. Asignar proveedor a los items
INSERT INTO ITEMS_PROVEEDORES (ItemId, ProveedorId, PrecioCompra, EsProveedorPrincipal) VALUES
    (@HarinaId, @ProveedorId, 250.50, 1),
    (@QuesoId, @ProveedorId, 850.00, 1),
    (@TomateId, @ProveedorId, 180.75, 1);

-- 5. Agregar stock inicial
UPDATE STOCK SET Cantidad = 1000, StockMinimo = 100 WHERE ItemId = @HarinaId;
UPDATE STOCK SET Cantidad = 500, StockMinimo = 50 WHERE ItemId = @QuesoId;
UPDATE STOCK SET Cantidad = 300, StockMinimo = 30 WHERE ItemId = @TomateId;

-- 6. Crear producto compuesto
DECLARE @PizzaId UNIQUEIDENTIFIER = NEWID();
INSERT INTO ITEMS (Id, Nombre, Unidad, UnidadEntera, CategoriaId, PrecioUnitario) VALUES
    (@PizzaId, 'Pizza Margarita', 1.0, 1, @CatTerminados, 1500.00);

-- 7. Definir composición del producto
INSERT INTO DETALLE_PRODUCTO (ItemPadreId, ItemComponenteId, CantidadConsumida, Orden) VALUES
    (@PizzaId, @HarinaId, 200, 1),    -- 200g de harina
    (@PizzaId, @QuesoId, 150, 2),     -- 150g de queso
    (@PizzaId, @TomateId, 100, 3);    -- 100g de salsa

COMMIT TRANSACTION;

PRINT '✓ Datos de ejemplo insertados correctamente';
