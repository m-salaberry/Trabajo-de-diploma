-- VISTAS ÚTILES
-- ==================================================

PRINT 'Creando vistas auxiliares...';

-- Vista: Items con Stock Bajo
IF OBJECT_ID('vw_ItemsStockBajo', 'V') IS NULL
BEGIN
    EXEC('
    CREATE VIEW vw_ItemsStockBajo AS
    SELECT 
        i.Id,
        i.Nombre,
        i.CodigoBarras,
        c.Nombre AS Categoria,
        s.Cantidad AS CantidadActual,
        s.StockMinimo,
        s.Ubicacion
    FROM ITEMS i
    INNER JOIN STOCK s ON i.Id = s.ItemId
    INNER JOIN CATEGORIA_ITEMS c ON i.CategoriaId = c.Id
    WHERE s.Cantidad <= s.StockMinimo AND i.IsActive = 1
    ');
    PRINT '✓ Vista vw_ItemsStockBajo creada';
END

-- Vista: Items con sus Proveedores
IF OBJECT_ID('vw_ItemsConProveedores', 'V') IS NULL
BEGIN
    EXEC('
    CREATE VIEW vw_ItemsConProveedores AS
    SELECT 
        i.Id AS ItemId,
        i.Nombre AS ItemNombre,
        ci.Nombre AS ItemCategoria,
        p.Id AS ProveedorId,
        p.Nombre AS ProveedorNombre,
        p.CUIT AS ProveedorCUIT,
        cp.Nombre AS ProveedorCategoria,
        p.TelefonoContacto AS ProveedorTelefono,
        p.Email AS ProveedorEmail,
        ip.PrecioCompra,
        ip.EsProveedorPrincipal,
        CASE 
            WHEN p.CategoriaItemId = i.CategoriaId THEN ''Compatible''
            ELSE ''Incompatible''
        END AS CompatibilidadCategoria
    FROM ITEMS i
    INNER JOIN ITEMS_PROVEEDORES ip ON i.Id = ip.ItemId
    INNER JOIN PROVEEDORES p ON ip.ProveedorId = p.Id
    INNER JOIN CATEGORIA_ITEMS ci ON i.CategoriaId = ci.Id
    INNER JOIN CATEGORIA_ITEMS cp ON p.CategoriaItemId = cp.Id
    WHERE i.IsActive = 1 AND p.IsActive = 1
    ');
    PRINT '✓ Vista vw_ItemsConProveedores creada';
END

-- Vista: Proveedores por Categoría
IF OBJECT_ID('vw_ProveedoresPorCategoria', 'V') IS NULL
BEGIN
    EXEC('
    CREATE VIEW vw_ProveedoresPorCategoria AS
    SELECT 
        c.Id AS CategoriaId,
        c.Nombre AS Categoria,
        p.Id AS ProveedorId,
        p.Nombre AS ProveedorNombre,
        p.CUIT AS ProveedorCUIT,
        p.TelefonoContacto,
        p.Email,
        COUNT(DISTINCT ip.ItemId) AS ItemsSuministrados
    FROM CATEGORIA_ITEMS c
    INNER JOIN PROVEEDORES p ON c.Id = p.CategoriaItemId
    LEFT JOIN ITEMS_PROVEEDORES ip ON p.Id = ip.ProveedorId
    WHERE p.IsActive = 1
    GROUP BY c.Id, c.Nombre, p.Id, p.Nombre, p.CUIT, p.TelefonoContacto, p.Email
    ');
    PRINT '✓ Vista vw_ProveedoresPorCategoria creada';
END

-- Vista: Composición de Productos
IF OBJECT_ID('vw_ComposicionProductos', 'V') IS NULL
BEGIN
    EXEC('
    CREATE VIEW vw_ComposicionProductos AS
    SELECT 
        iPadre.Id AS ProductoId,
        iPadre.Nombre AS ProductoNombre,
        iComponente.Id AS ComponenteId,
        iComponente.Nombre AS ComponenteNombre,
        dp.CantidadConsumida,
        dp.Orden
    FROM DETALLE_PRODUCTO dp
    INNER JOIN ITEMS iPadre ON dp.ItemPadreId = iPadre.Id
    INNER JOIN ITEMS iComponente ON dp.ItemComponenteId = iComponente.Id
    WHERE iPadre.IsActive = 1 AND iComponente.IsActive = 1
    ');
    PRINT '✓ Vista vw_ComposicionProductos creada';
END

