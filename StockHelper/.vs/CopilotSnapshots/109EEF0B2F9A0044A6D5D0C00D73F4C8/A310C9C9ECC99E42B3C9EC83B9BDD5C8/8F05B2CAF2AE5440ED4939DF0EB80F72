-- ==================================================
-- TABLA 1: CATEGORIA_ITEMS (CategoriaItem)
-- ==================================================

PRINT 'Creando tabla CATEGORIA_ITEMS...';

IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'CATEGORIA_ITEMS')
BEGIN
    CREATE TABLE CATEGORIA_ITEMS (
        Id INT IDENTITY(1,1) NOT NULL,
        Nombre NVARCHAR(100) NOT NULL,
        
        CONSTRAINT PK_CATEGORIA_ITEMS PRIMARY KEY (Id),
        CONSTRAINT UQ_CATEGORIA_ITEMS_Nombre UNIQUE (Nombre)
    );
    
    -- Índice para búsquedas por nombre
    CREATE INDEX IX_CATEGORIA_ITEMS_Nombre ON CATEGORIA_ITEMS(Nombre);
    
    PRINT '✓ Tabla CATEGORIA_ITEMS creada exitosamente';
END
ELSE
BEGIN
    PRINT '⚠ Tabla CATEGORIA_ITEMS ya existe, omitiendo creación';
END
PRINT '';

-- ==================================================
-- TABLA 2: PROVEEDORES (Proveedor)
-- ==================================================

PRINT 'Creando tabla PROVEEDORES...';

IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'PROVEEDORES')
BEGIN
    CREATE TABLE PROVEEDORES (
        Id UNIQUEIDENTIFIER NOT NULL DEFAULT NEWID(),
        CUIT BIGINT NOT NULL,
        Nombre NVARCHAR(200) NOT NULL,
        RazonSocial NVARCHAR(300) NOT NULL,
        CategoriaItemId INT NOT NULL,
        TelefonoContacto BIGINT NULL,
        Email NVARCHAR(200) NULL,
        Direccion NVARCHAR(500) NULL,
        IsActive BIT NOT NULL DEFAULT 1,
        CreatedDate DATETIME NOT NULL DEFAULT GETDATE(),
        ModifiedDate DATETIME NULL,
        
        CONSTRAINT PK_PROVEEDORES PRIMARY KEY (Id),
        CONSTRAINT FK_PROVEEDORES_CategoriaItemId FOREIGN KEY (CategoriaItemId) 
            REFERENCES CATEGORIA_ITEMS(Id),
        CONSTRAINT UQ_PROVEEDORES_CUIT UNIQUE (CUIT),
        CONSTRAINT CK_PROVEEDORES_CUIT CHECK (CUIT > 0)
    );
    
    -- Índices para búsquedas comunes
    CREATE INDEX IX_PROVEEDORES_Nombre ON PROVEEDORES(Nombre);
    CREATE INDEX IX_PROVEEDORES_CUIT ON PROVEEDORES(CUIT);
    CREATE INDEX IX_PROVEEDORES_CategoriaItemId ON PROVEEDORES(CategoriaItemId);
    CREATE INDEX IX_PROVEEDORES_IsActive ON PROVEEDORES(IsActive);
    
    PRINT '✓ Tabla PROVEEDORES creada exitosamente';
END
ELSE
BEGIN
    PRINT '⚠ Tabla PROVEEDORES ya existe, omitiendo creación';
END
PRINT '';

-- ==================================================
-- TABLA 3: ITEMS (Item)
-- ==================================================

PRINT 'Creando tabla ITEMS...';

IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'ITEMS')
BEGIN
    CREATE TABLE ITEMS (
        Id UNIQUEIDENTIFIER NOT NULL DEFAULT NEWID(),
        Nombre NVARCHAR(200) NOT NULL,
        Unidad DECIMAL(18,4) NOT NULL DEFAULT 1.0,
        UnidadEntera BIT NOT NULL DEFAULT 1,
        CategoriaId INT NOT NULL,
        CodigoBarras NVARCHAR(50) NULL,
        Descripcion NVARCHAR(MAX) NULL,
        PrecioUnitario DECIMAL(18,2) NULL,
        IsActive BIT NOT NULL DEFAULT 1,
        CreatedDate DATETIME NOT NULL DEFAULT GETDATE(),
        ModifiedDate DATETIME NULL,
        
        CONSTRAINT PK_ITEMS PRIMARY KEY (Id),
        CONSTRAINT FK_ITEMS_CategoriaId FOREIGN KEY (CategoriaId) 
            REFERENCES CATEGORIA_ITEMS(Id) ON DELETE CASCADE,
        CONSTRAINT UQ_ITEMS_Nombre UNIQUE (Nombre),
        CONSTRAINT CK_ITEMS_Unidad CHECK (Unidad > 0),
        CONSTRAINT CK_ITEMS_PrecioUnitario CHECK (PrecioUnitario IS NULL OR PrecioUnitario >= 0)
    );
    
    -- Índices para búsquedas comunes
    CREATE INDEX IX_ITEMS_Nombre ON ITEMS(Nombre);
    CREATE INDEX IX_ITEMS_CategoriaId ON ITEMS(CategoriaId);
    CREATE INDEX IX_ITEMS_CodigoBarras ON ITEMS(CodigoBarras);
    CREATE INDEX IX_ITEMS_IsActive ON ITEMS(IsActive);
    
    PRINT '✓ Tabla ITEMS creada exitosamente';
END
ELSE
BEGIN
    PRINT '⚠ Tabla ITEMS ya existe, omitiendo creación';
END
PRINT '';

-- ==================================================
-- TABLA 4: STOCK (Stock)
-- ==================================================

PRINT 'Creando tabla STOCK...';

IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'STOCK')
BEGIN
    CREATE TABLE STOCK (
        Id UNIQUEIDENTIFIER NOT NULL DEFAULT NEWID(),
        ItemId UNIQUEIDENTIFIER NOT NULL,
        Cantidad INT NOT NULL DEFAULT 0,
        StockMinimo INT NULL DEFAULT 0,
        StockMaximo INT NULL,
        Ubicacion NVARCHAR(100) NULL,
        LastUpdated DATETIME NOT NULL DEFAULT GETDATE(),
        
        CONSTRAINT PK_STOCK PRIMARY KEY (Id),
        CONSTRAINT FK_STOCK_ItemId FOREIGN KEY (ItemId) 
            REFERENCES ITEMS(Id) ON DELETE CASCADE,
        CONSTRAINT UQ_STOCK_ItemId UNIQUE (ItemId),
        CONSTRAINT CK_STOCK_Cantidad CHECK (Cantidad >= 0),
        CONSTRAINT CK_STOCK_StockMinimo CHECK (StockMinimo IS NULL OR StockMinimo >= 0),
        CONSTRAINT CK_STOCK_StockMaximo CHECK (StockMaximo IS NULL OR StockMaximo >= StockMinimo)
    );
    
    -- Índices para búsquedas comunes
    CREATE INDEX IX_STOCK_ItemId ON STOCK(ItemId);
    CREATE INDEX IX_STOCK_Cantidad ON STOCK(Cantidad);
    CREATE INDEX IX_STOCK_StockBajo ON STOCK(Cantidad, StockMinimo) 
        WHERE Cantidad <= StockMinimo;
    
    PRINT '✓ Tabla STOCK creada exitosamente';
END
ELSE
BEGIN
    PRINT '⚠ Tabla STOCK ya existe, omitiendo creación';
END
PRINT '';

