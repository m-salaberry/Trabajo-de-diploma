CREATE TRIGGER trg_Items_UpdateModifiedDate
ON ITEMS
AFTER UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    
    UPDATE ITEMS
    SET ModifiedDate = GETDATE()
    FROM ITEMS i
    INNER JOIN inserted ins ON i.Id = ins.Id;
END
