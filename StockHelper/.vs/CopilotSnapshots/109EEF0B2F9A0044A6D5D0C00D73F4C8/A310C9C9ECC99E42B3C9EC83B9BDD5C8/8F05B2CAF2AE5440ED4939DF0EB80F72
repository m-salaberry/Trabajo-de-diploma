-- SP: Obtener Stock Actual de un Item
IF OBJECT_ID('sp_GetStockByItem', 'P') IS NOT NULL
    DROP PROCEDURE sp_GetStockByItem;
GO

CREATE PROCEDURE sp_GetStockByItem
    @ItemId UNIQUEIDENTIFIER
AS
BEGIN
    SET NOCOUNT ON;
    
    SELECT 
        i.Id AS ItemId,
        i.Nombre AS ItemNombre,
        s.Cantidad AS CantidadActual,
        s.StockMinimo,
        s.StockMaximo,
        s.Ubicacion,
        s.LastUpdated,
        CASE 
            WHEN s.Cantidad <= 0 THEN 'Sin Stock'
            WHEN s.Cantidad <= s.StockMinimo THEN 'Stock Bajo'
            WHEN s.Cantidad >= s.StockMaximo THEN 'Stock Alto'
            ELSE 'Stock Normal'
        END AS EstadoStock
    FROM ITEMS i
    INNER JOIN STOCK s ON i.Id = s.ItemId
    WHERE i.Id = @ItemId;
END
GO

PRINT '✓ Stored Procedure sp_GetStockByItem creado';

-- SP: Actualizar Stock de un Item
IF OBJECT_ID('sp_UpdateStock', 'P') IS NOT NULL
    DROP PROCEDURE sp_UpdateStock;
GO

CREATE PROCEDURE sp_UpdateStock
    @ItemId UNIQUEIDENTIFIER,
    @CantidadCambio INT,
    @Operacion VARCHAR(10) = 'ADD' -- 'ADD' o 'SUBTRACT'
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    
    BEGIN TRY
        DECLARE @CantidadActual INT;
        
        -- Obtener cantidad actual
        SELECT @CantidadActual = Cantidad 
        FROM STOCK 
        WHERE ItemId = @ItemId;
        
        -- Validar que existe el registro
        IF @CantidadActual IS NULL
        BEGIN
            RAISERROR('Stock record not found for the specified item', 16, 1);
            RETURN;
        END
        
        -- Calcular nueva cantidad
        DECLARE @NuevaCantidad INT;
        IF @Operacion = 'ADD'
            SET @NuevaCantidad = @CantidadActual + @CantidadCambio;
        ELSE IF @Operacion = 'SUBTRACT'
            SET @NuevaCantidad = @CantidadActual - @CantidadCambio;
        ELSE
        BEGIN
            RAISERROR('Invalid operation. Use ADD or SUBTRACT', 16, 1);
            RETURN;
        END
        
        -- Validar que no quede negativo
        IF @NuevaCantidad < 0
        BEGIN
            RAISERROR('Insufficient stock. Current: %d, Requested: %d', 16, 1, @CantidadActual, @CantidadCambio);
            RETURN;
        END
        
        -- Actualizar stock
        UPDATE STOCK 
        SET Cantidad = @NuevaCantidad,
            LastUpdated = GETDATE()
        WHERE ItemId = @ItemId;
        
        COMMIT TRANSACTION;
        
        -- Retornar nuevo estado
        SELECT 
            ItemId,
            Cantidad AS NuevaCantidad,
            LastUpdated
        FROM STOCK 
        WHERE ItemId = @ItemId;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END
GO

PRINT '✓ Stored Procedure sp_UpdateStock creado';

-- SP: Validar compatibilidad Proveedor-Item por categoría
IF OBJECT_ID('sp_ValidateProveedorItemCompatibility', 'P') IS NOT NULL
    DROP PROCEDURE sp_ValidateProveedorItemCompatibility;
GO

CREATE PROCEDURE sp_ValidateProveedorItemCompatibility
    @ProveedorId UNIQUEIDENTIFIER,
    @ItemId UNIQUEIDENTIFIER
AS
BEGIN
    SET NOCOUNT ON;
    
    DECLARE @ProveedorCategoriaId INT;
    DECLARE @ItemCategoriaId INT;
    
    -- Obtener categoría del proveedor
    SELECT @ProveedorCategoriaId = CategoriaItemId 
    FROM PROVEEDORES 
    WHERE Id = @ProveedorId;
    
    -- Obtener categoría del item
    SELECT @ItemCategoriaId = CategoriaId 
    FROM ITEMS 
    WHERE Id = @ItemId;
    
    -- Validar que ambos existen
    IF @ProveedorCategoriaId IS NULL OR @ItemCategoriaId IS NULL
    BEGIN
        SELECT 
            0 AS IsValid,
            'Provider or Item not found' AS Message;
        RETURN;
    END
    
    -- Comparar categorías
    IF @ProveedorCategoriaId = @ItemCategoriaId
    BEGIN
        SELECT 
            1 AS IsValid,
            'Compatible: Provider and Item are in the same category' AS Message,
            (SELECT Nombre FROM CATEGORIA_ITEMS WHERE Id = @ItemCategoriaId) AS Category;
    END
    ELSE
    BEGIN
        SELECT 
            0 AS IsValid,
            'Incompatible: Provider specializes in different category' AS Message,
            (SELECT Nombre FROM CATEGORIA_ITEMS WHERE Id = @ProveedorCategoriaId) AS ProviderCategory,
            (SELECT Nombre FROM CATEGORIA_ITEMS WHERE Id = @ItemCategoriaId) AS ItemCategory;
    END
END
GO

PRINT '✓ Stored Procedure sp_ValidateProveedorItemCompatibility creado';
