-- Trigger: Auto-crear registro de Stock al crear Item
IF OBJECT_ID('trg_Items_CreateStock', 'TR') IS NOT NULL
    DROP TRIGGER trg_Items_CreateStock;
GO

CREATE TRIGGER trg_Items_CreateStock
ON ITEMS
AFTER INSERT
AS
BEGIN
    SET NOCOUNT ON;
    
    INSERT INTO STOCK (Id, ItemId, Cantidad, StockMinimo, LastUpdated)
    SELECT NEWID(), i.Id, 0, 10, GETDATE()
    FROM inserted i
    WHERE NOT EXISTS (
        SELECT 1 FROM STOCK s WHERE s.ItemId = i.Id
    );
END
GO

PRINT '✓ Trigger trg_Items_CreateStock creado';

